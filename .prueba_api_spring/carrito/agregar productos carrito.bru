meta {
  name: agregar productos carrito
  type: http
  seq: 2
}

post {
  url: http://localhost:8083/api/v1/carritos/{{carritoId}}/productos
  body: json
  auth: inherit
}

body:json {
  {
    "productoId": "{{productoId}}",
    "cantidad": 1
  }
}

script:post-response {
  let data = res.getBody();
  let carritoId = data.carritoId;
  if(carritoId){
    bru.setVar("carritoId", carritoId);  
  }
  
}

settings {
  encodeUrl: true
  timeout: 0
}
