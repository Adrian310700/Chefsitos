{
  "uid": "uamishop-k6",
  "title": "UAMIShop - k6 v2",
  "tags": ["k6", "victoriametrics", "uamishop", "performance"],
  "timezone": "",
  "schemaVersion": 39,
  "version": 2,
  "refresh": "5s",
  "time": {
    "from": "now-30m",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "testid",
        "type": "query",
        "label": "Test ID",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(k6_http_reqs_total, testid)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 3,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "test_type",
        "type": "query",
        "label": "Test Type",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(k6_http_reqs_total, test_type)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 3,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      },
      {
        "name": "endpoint",
        "type": "query",
        "label": "Endpoint",
        "datasource": {
          "type": "prometheus",
          "uid": "victoriametrics"
        },
        "query": "label_values(k6_http_reqs_total, name)",
        "includeAll": true,
        "multi": true,
        "refresh": 2,
        "sort": 3,
        "current": {
          "selected": true,
          "text": "All",
          "value": "$__all"
        }
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Resumen",
      "gridPos": { "x": 0, "y": 0, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 1,
      "type": "stat",
      "title": "Requests/s",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 0, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_http_reqs_total{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"}[$__rate_interval]))"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Error rate",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 6, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_failed_rate{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 latency",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 12, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_duration_p95{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "P99 latency",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 18, "y": 1, "w": 6, "h": 4 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_duration_p99{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"})"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] }
    },

    {
      "type": "row",
      "title": "Latencia",
      "gridPos": { "x": 0, "y": 5, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "P95 por endpoint",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 0, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_duration_p95{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"}) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Waiting time P95 por endpoint",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 12, "y": 6, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_waiting_p95{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"}) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "single" }
      }
    },

    {
      "type": "row",
      "title": "Errores",
      "gridPos": { "x": 0, "y": 14, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Error rate por endpoint",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 0, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_http_req_failed_rate{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"}) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit" }, "overrides": [] }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Checks aprobados",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 12, "y": 15, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_checks_total{testid=~\"$testid\",test_type=~\"$test_type\"}[$__rate_interval])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },

    {
      "type": "row",
      "title": "Throughput",
      "gridPos": { "x": 0, "y": 23, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Requests/s por endpoint",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 0, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_http_reqs_total{testid=~\"$testid\",test_type=~\"$test_type\",name=~\"$endpoint\"}[$__rate_interval])) by (name)",
          "legendFormat": "{{name}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] }
    },
    {
      "id": 10,
      "type": "timeseries",
      "title": "Iterations/s",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 12, "y": 24, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_iterations_total{testid=~\"$testid\",test_type=~\"$test_type\"}[$__rate_interval]))",
          "legendFormat": "iterations/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    },

    {
      "type": "row",
      "title": "Capacidad",
      "gridPos": { "x": 0, "y": 32, "w": 24, "h": 1 },
      "collapsed": false,
      "panels": []
    },
    {
      "id": 11,
      "type": "timeseries",
      "title": "Virtual users",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 0, "y": 33, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "max(k6_vus{testid=~\"$testid\",test_type=~\"$test_type\"})",
          "legendFormat": "vus"
        },
        {
          "refId": "B",
          "expr": "max(k6_vus_max{testid=~\"$testid\",test_type=~\"$test_type\"})",
          "legendFormat": "vus_max"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "short" }, "overrides": [] }
    },
    {
      "id": 12,
      "type": "timeseries",
      "title": "Dropped iterations",
      "datasource": { "type": "prometheus", "uid": "victoriametrics" },
      "gridPos": { "x": 12, "y": 33, "w": 12, "h": 8 },
      "targets": [
        {
          "refId": "A",
          "expr": "sum(rate(k6_dropped_iterations_total{testid=~\"$testid\",test_type=~\"$test_type\"}[$__rate_interval]))",
          "legendFormat": "dropped_iterations/s"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops" }, "overrides": [] }
    }
  ]
}
